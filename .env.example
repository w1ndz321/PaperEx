# ─── LLM 调用 ──────────────────────────────────────────────────
OPENAI_API_KEY="your_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="deepseek-v3.2"
LLM_TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=8000
MAX_RETRIES=3

# ─── 文本处理 ──────────────────────────────────────────────────
MAX_INPUT_CHARS=40000
METADATA_HEAD_CHARS=3000
MIN_MD_CHARS=10000

# ─── 运行控制 ──────────────────────────────────────────────────
WORKERS=10
# 单次处理文件数上限，0 或不设表示处理全部（用于测试）
PROCESS_LIMIT=0
